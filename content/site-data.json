      {
        "eyebrow": "Faster launch",
        "title": "Listings can move from shoot to market quickly.",
        "text": "Same-day availability when possible and next-day delivery keep agents moving when a property is ready to go live."
      },
      {
        "eyebrow": "Platform ready",
        "title": "Media is built for the way agents actually market listings.",
        "text": "The deliverables are positioned around MLS-ready photos, Zillow-ready images, HDR photography, drone work, and social-first video."
      },
      {
        "eyebrow": "Simple handoff",
        "title": "Media is easy to review, download, and share.",
        "text": "The client delivery portal is designed to feel organized instead of technical, so agents can open the gallery and get moving fast."
      }
    ],
    "contactLead": "Send the property address, target timeline, and the kind of coverage you need. Same-day availability is offered when the schedule allows.",
